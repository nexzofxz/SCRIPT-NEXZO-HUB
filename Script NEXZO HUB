-- ================== CÁLCULO DE ALVO (DISTÂNCIA DO JOGADOR) ==================

local function getClosestPlayerToMe()
    local closestPlayer = nil
    local shortestDistance = math.huge
    
    local myChar = lPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end

    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= lPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                if teamCheckEnabled and p.Team == lPlayer.Team then
                    continue
                end

                local targetHrp = p.Character.HumanoidRootPart
                local distance = (myHrp.Position - targetHrp.Position).Magnitude

                if distance < shortestDistance then
                    closestPlayer = p
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end


-- ================== LOOPS DE BACKGROUND GERENCIAIS ==================

game:GetService("RunService").RenderStepped:Connect(function()
    if aimbotEnabled then
        local target = getClosestPlayerToMe()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            camera.CFrame = CFrame.new(camera.CFrame.Position, target.Character.Head.Position)
        end
    end
    
    -- --- LOOP DA BIBLIOTECA DRAWING 2D (BOX, TRACER, HEALTH) ---
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= lPlayer then
            local char = p.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if playersEspEnabled and char and humanoid and hrp and humanoid.Health > 0 then
                local hrpPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen then
                    if not drawingCache[p] then
                        drawingCache[p] = {
                            Box = Drawing.new("Square"),
                            Tracer = Drawing.new("Line"),
                            HealthOutline = Drawing.new("Square"),
                            HealthBar = Drawing.new("Square")
                        }
                    end
                    
                    local draw = drawingCache[p]
                    
                    local head = char:FindFirstChild("Head")
                    local headPos = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or hrpPos
                    local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                    
                    local boxHeight = math.abs(headPos.Y - legPos.Y)
                    local boxWidth = boxHeight / 1.5
                    local boxX = hrpPos.X - (boxWidth / 2)
                    local boxY = headPos.Y
                    
                    -- 1. Desenho da Box
                    if showBox then
                        draw.Box.Size = Vector2.new(boxWidth, boxHeight)
                        draw.Box.Position = Vector2.new(boxX, boxY)
                        draw.Box.Color = Color3.fromRGB(0, 150, 255)
                        draw.Box.Thickness = 1.5
                        draw.Box.Filled = false
                        draw.Box.Visible = true
                    else
                        draw.Box.Visible = false
                    end
                    
                    -- 2. Desenho do Tracer
                    if showTracer then
                        draw.Tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        draw.Tracer.To = Vector2.new(hrpPos.X, hrpPos.Y)
                        draw.Tracer.Color = Color3.fromRGB(0, 150, 255)
                        draw.Tracer.Thickness = 1.2
                        draw.Tracer.Visible = true
                    else
                        draw.Tracer.Visible = false
                    end
                    
                    -- 3. Desenho da Health Bar
                    if showHealthBar then
                        local barX = boxX - 6
                        local healthPercentage = humanoid.Health / humanoid.MaxHealth
                        local healthHeight = boxHeight * healthPercentage
                        local healthY = boxY + (boxHeight - healthHeight)
                        
                        draw.HealthOutline.Size = Vector2.new(3, boxHeight)
                        draw.HealthOutline.Position = Vector2.new(barX, boxY)
                        draw.HealthOutline.Color = Color3.fromRGB(0, 0, 0)
                        draw.HealthOutline.Filled = true
                        draw.HealthOutline.Visible = true
                        
                        draw.HealthBar.Size = Vector2.new(3, healthHeight)
                        draw.HealthBar.Position = Vector2.new(barX, healthY)
                        draw.HealthBar.Color = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), healthPercentage)
                        draw.HealthBar.Filled = true
                        draw.HealthBar.Visible = true
                    else
                        draw.HealthOutline.Visible = false
                        draw.HealthBar.Visible = false
                    end
                else
                    removeDrawing(p)
                end
            else
                removeDrawing(p)
            end
        end
    end
end)

-- Loop Heartbeat para Mecânicas Físicas e Modificadores
game:GetService("RunService").Heartbeat:Connect(function()
    local char = lPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if char and humanoid and hrp then
        if humanoid and not defaultJumpPower and not defaultJumpHeight then
            defaultJumpPower = humanoid.JumpPower
            defaultJumpHeight = humanoid.JumpHeight
        end
        
        -- Lógica do TpWalk
        if tpWalkEnabled and humanoid.MoveDirection.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (humanoid.MoveDirection * (tpWalkSpeed / 100))
        end
        
        -- Lógica de Altura de Pulo
        if jumpEnabled then
            if humanoid.UseJumpPower and humanoid.JumpPower ~= jumpHeightValue then
                humanoid.JumpPower = jumpHeightValue
            elseif not humanoid.UseJumpPower and humanoid.JumpHeight ~= jumpHeightValue then
                humanoid.JumpHeight = jumpHeightValue
            end
        end
        
        -- Lógica de Vôo
        local bv = hrp:FindFirstChild("NEXZO_FlyBV")
        if flyEnabled and bv then
            if humanoid.MoveDirection.Magnitude > 0 then
                bv.Velocity = camera.CFrame.LookVector * flySpeed
            else
                bv.Velocity = Vector3.new(0, 0, 0)
            end
        end
    end
    
    -- Lógica do NoClip
    if noclipEnabled and char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
    
    -- Forçar Câmera e FOV em Tempo Real
    if thirdPersonEnabled then
        lPlayer.CameraMaxZoomDistance = 100
        lPlayer.CameraMinZoomDistance = 20
    end
    
    if camera.FieldOfView ~= defaultFOV then
        camera.FieldOfView = defaultFOV
    end
    
    if noFogEnabled then
        Lighting.FogStart = 9e9
        Lighting.FogEnd = 9e9
        local atm = Lighting:FindFirstChildOfClass("Atmosphere")
        if atm then atm.Parent = nil end
    end
    
    -- Limpeza Automática de Cache de mortos/desconectados
    for char, hl in pairs(normalEspHighlights) do
        if not char.Parent or not char:FindFirstChild("Humanoid") then removeNormalESP(char) end
    end
    
    for char, hl in pairs(teamCheckHighlights) do
        if not char.Parent or not char:FindFirstChild("Humanoid") then removeTeamCheckESP(char) end
    end
    
    for model, hl in pairs(npcHighlights) do
        if not model.Parent or not model:FindFirstChild("Humanoid") then removeNpcESP(model) end
    end
    
    for p, _ in pairs(drawingCache) do
        if not game.Players:FindFirstChild(p.Name) then removeDrawing(p) end
    end
end)

