-- ================== FUNÇÃO DE AUXÍLIO: REMOVER DESENHOS 2D ==================

local function removeDrawing(player)
    if drawingCache[player] then
        pcall(function()
            drawingCache[player].Box.Visible = false
            drawingCache[player].Box:Remove()
            
            drawingCache[player].Tracer.Visible = false
            drawingCache[player].Tracer:Remove()
            
            drawingCache[player].HealthOutline.Visible = false
            drawingCache[player].HealthOutline:Remove()
            
            drawingCache[player].HealthBar.Visible = false
            drawingCache[player].HealthBar:Remove()
        end)
        drawingCache[player] = nil
    end
end


-- ================== FUNÇÃO: ESP NORMAL (SOMENTE AZUL) ==================

local function createNormalESP(character)
    if not character or normalEspHighlights[character] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "NormalESP_HL"
    highlight.Adornee = character
    highlight.FillColor = Color3.fromRGB(0, 150, 255)
    highlight.OutlineColor = Color3.fromRGB(0, 150, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0 
    highlight.Parent = character
    
    local head = character:FindFirstChild("Head")
    if head then
        local bbG = Instance.new("BillboardGui")
        bbG.Name = "NormalESP_BBG"
        bbG.AlwaysOnTop = true
        bbG.Size = UDim2.new(0, 200, 0, 50)
        bbG.StudsOffset = Vector3.new(0, 2.5, 0)
        bbG.Parent = character
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = character.Name
        label.TextColor3 = Color3.fromRGB(0, 150, 255)
        label.TextSize = 10
        label.Font = Enum.Font.GothamBold
        label.TextStrokeTransparency = 0
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.Parent = bbG
    end
    
    normalEspHighlights[character] = highlight
end

local function removeNormalESP(character)
    if normalEspHighlights[character] then
        normalEspHighlights[character]:Destroy()
        normalEspHighlights[character] = nil
    end
    local bbG = character:FindFirstChild("NormalESP_BBG")
    if bbG then bbG:Destroy() end
