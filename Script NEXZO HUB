        end
        
        -- Loops de ESP
        for _, p in ipairs(game.Players:GetPlayers()) do
            if p ~= lPlayer and p.Character then
                if playersEspEnabled then
                    createNormalESP(p.Character)
                else
                    removeNormalESP(p.Character)
                    removeDrawing(p)
                end
                
                if teamCheckEspEnabled then
                    createTeamCheckESP(p.Character, p.Team == lPlayer.Team)
                else
                    removeTeamCheckESP(p.Character)
                end
            end
        end
        
        if npcsEspEnabled then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and isNPC(obj) and obj ~= lPlayer.Character then
                    createNpcESP(obj)
                end
            end
        end
    end
end)

game.Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if playersEspEnabled then createNormalESP(char) end
        if teamCheckEspEnabled then createTeamCheckESP(char, plr.Team == lPlayer.Team) end
    end)
end)

game.Players.PlayerRemoving:Connect(function(plr)
    removeDrawing(plr)
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if infJumpEnabled then
        pcall(function()
            local character = lPlayer.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end)

