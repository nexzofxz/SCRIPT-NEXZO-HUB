-- ================== FUNÇÃO: SISTEMA UNIVERSAL DE X-RAY ==================

local function applyXray(state)
    xrayEnabled = state
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(lPlayer.Character) and not game.Players:GetPlayerFromCharacter(obj.Parent) then
            -- Ignorar NPCs também para não quebrar o visual deles
            if not obj.Parent:FindFirstChild("Humanoid") then
                if state then
                    if not xrayCache[obj] then
                        xrayCache[obj] = obj.Transparency
                    end
                    obj.Transparency = 0.65
                else
                    if xrayCache[obj] then
                        obj.Transparency = xrayCache[obj]
                        xrayCache[obj] = nil
                    else
                        obj.Transparency = 0
                    end
                end
            end
        end
    end
end


